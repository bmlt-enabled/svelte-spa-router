{
    "name": "@bmlt-enabled/svelte-spa-router",
    "version": "5.1.1",
    "description": "Router for SPAs using Svelte 5",
    "main": "Router.svelte",
    "svelte": "Router.svelte",
    "types": "Router.d.ts",
    "type": "module",
    "exports": {
        "./active": {
            "types": "./active.d.ts",
            "import": "./active.svelte.js"
        },
        "./wrap": {
            "types": "./wrap.d.ts",
            "import": "./wrap.js"
        },
        ".": {
            "types": "./Router.d.ts",
            "svelte": "./Router.svelte"
        }
    },
    "files": [
        "Router.svelte",
        "Router.d.ts",
        "active.svelte.js",
        "active.d.ts",
        "wrap.js",
        "wrap.d.ts",
        "regexparam.js",
        "regexparam.d.ts",
        "LICENSE",
        "README.md",
        "CONTRIBUTING.md"
    ],
    "scripts": {
        "lint": "npx eslint .",
        "lint:fix": "npx eslint --fix .",
        "format": "npx prettier --write \"**/*.{js,ts,svelte}\"",
        "format:check": "npx prettier --check \"**/*.{js,ts,svelte}\"",
        "test:unit": "npx vitest run",
        "test:e2e": "npx playwright test",
        "test": "npm run test:unit && npm run test:e2e",
        "dev:example": "npx vite --config examples/basic-routing/vite.config.js --port 5050",
        "dev:test": "npx vite --config tests/app/vite.config.js --port 5051",
        "dev:test-path": "npx vite --config tests/app-path/vite.config.js --port 5052"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/bmlt-enabled/svelte-spa-router.git"
    },
    "keywords": [
        "router",
        "svelte",
        "svelte5",
        "spa"
    ],
    "author": "BMLT Enabled",
    "license": "MIT",
    "bugs": {
        "url": "https://github.com/bmlt-enabled/svelte-spa-router/issues"
    },
    "homepage": "https://github.com/bmlt-enabled/svelte-spa-router#readme",
    "devDependencies": {
        "@playwright/test": "^1.58.2",
        "@sveltejs/vite-plugin-svelte": "^7.0.0",
        "eslint": "^10.1.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-svelte": "^3.15.2",
        "globals": "^17.4.0",
        "prettier": "^3.8.1",
        "prettier-plugin-svelte": "^3.5.1",
        "serve": "^14.2.6",
        "svelte": "^5.0.0",
        "vite": "^8.0.0",
        "vitest": "^4.1.0"
    }
}
